generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EventLog {
  id         String   @id @default(cuid())
  accountId  String?
  platform   String
  direction  String
  eventType  String
  fromNumber String?
  toNumber   String?
  payload    Json
  createdAt  DateTime @default(now())
}

model Message {
  id                String   @id @default(cuid())
  accountId         String?
  platform          String
  direction         String
  externalMessageId String?
  chatId            String?
  fromNumber        String?
  toNumber          String?
  senderName        String?
  accountPhone      String?
  accountPhoneId    String?
  text              String?
  messageType       String
  isGroup           Boolean  @default(false)
  groupId           String?
  groupName         String?
  mediaType         String?
  mediaMimeType     String?
  mediaId           String?
  mediaSha256       String?
  mediaCaption      String?
  contactName       String?
  contactPhone      String?
  contacts          Json?
  payload           Json
  sentAt            DateTime?
  createdAt         DateTime @default(now())
}

model CloudAccountConfig {
  id            String   @id @default(cuid())
  accountId     String   @unique
  displayName   String?
  phoneNumberId String
  accessToken   String
  verifyToken   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AccountInfo {
  id           String   @id @default(cuid())
  accountId    String   @unique
  connector    String
  displayName  String?
  phoneNumber  String?
  phoneNumberId String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

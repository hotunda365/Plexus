# Server
PORT=3000
BASE_URL=http://localhost:3000

# Choose connector: cloud | personal | both
CONNECTOR_MODE=both

# Database (PostgreSQL example)
# DATABASE_URL="postgresql://username:password@host:5432/database"
DATABASE_URL="postgresql://root:replace_password@localhost:5432/zeabur"

# ==========================
# WhatsApp Business Cloud API
# ==========================
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_VERIFY_TOKEN=replace_with_a_secret
# Optional legacy JSON format. If provided, only the first entry is used.
# WA_CLOUD_ACCOUNTS_JSON=[{"phoneNumberId":"123","accessToken":"EA...","verifyToken":"vt"}]

# ==========================
# Personal WhatsApp (whatsapp-web.js)
# ==========================
WA_PERSONAL_SESSION_DIR=.wwebjs_auth
# Optional legacy JSON format. If provided, only the first entry is used.
# WA_PERSONAL_ACCOUNTS_JSON=[{"sessionDir":".wwebjs_auth"}]
